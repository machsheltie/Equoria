# =============================================================================
# Equoria — Canonical Environment Variable Reference (.env.example)
# =============================================================================
# This is the single, comprehensive reference for EVERY environment variable
# the Equoria codebase reads (backend, frontend, and the test/CI harness).
#
# Copy this file to `.env` and fill in real values for your environment:
#     cp .env.example .env
#
# Component-scoped examples also exist and stay in sync with this file:
#   - backend/.env.example          backend runtime (most vars below live here)
#   - backend/env.beta.example      NODE_ENV=beta deploy preset
#   - frontend/.env.example         Vite frontend build (VITE_* only)
#
# Var values below are SAFE PLACEHOLDERS. Never commit real secrets.
# "Generate with:" lines show how to mint strong values.
#
# Grouping legend:
#   [REQUIRED]      — app fails fast / cannot run without this (in the noted env)
#   [OPTIONAL]      — has a safe default; set only to override
#   [TEST/CI ONLY]  — consumed by the Jest/Playwright harness, not production
#
# Several secrets are validated by backend/utils/runtimeSecretPolicy.mjs and
# fail fast at startup in NODE_ENV=production or beta when missing, a known
# placeholder, or shorter than 32 chars. See .claude/rules/SECURITY.md.
# =============================================================================


# =============================================================================
# CORE SERVER  (backend/config/config.mjs)
# =============================================================================

# [REQUIRED] Runtime mode. One of: development | test | beta | production.
# Drives every fail-fast secret policy and security default below.
NODE_ENV=development

# [REQUIRED] HTTP port the Express server binds to.
PORT=3000


# =============================================================================
# DATABASE  (packages/database — Prisma; DATABASE_URL validated in config.mjs)
# =============================================================================

# [REQUIRED] PostgreSQL connection string. Use a strong DB password.
# Generate password with: openssl rand -base64 32
DATABASE_URL="postgresql://postgres:REPLACE_WITH_STRONG_PASSWORD@localhost:5432/equoria"

# [OPTIONAL] Prisma connection pool tuning (see docs/implementation/SCALE-CONFIG.md).
# Appended to DATABASE_URL as connection_limit / pool_timeout / connect_timeout.
DB_POOL_SIZE=20
DB_POOL_TIMEOUT=30
DB_CONNECT_TIMEOUT=30


# =============================================================================
# AUTH / SECRETS  (fail-fast in production|beta — runtimeSecretPolicy.mjs)
# =============================================================================

# [REQUIRED] Signs/verifies access tokens. Min 32 chars; must differ from refresh.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# [REQUIRED] Signs/verifies refresh tokens. Min 32 chars; MUST differ from JWT_SECRET.
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_RANDOM_SECRET_MIN_32_CHARS

# [OPTIONAL] JWT key-rotation overlap (ADR-009). Set the OLD secret here DURING a
# rotation so tokens signed with it still verify; unset once the window closes.
# JWT_SECRET_PREVIOUS=
# JWT_REFRESH_SECRET_PREVIOUS=

# [OPTIONAL] Access/refresh token lifetimes (consumed by the auth controller).
JWT_ACCESS_TOKEN_EXPIRY=24h
JWT_REFRESH_TOKEN_EXPIRY=7d

# [REQUIRED before production] Session secret (SECURITY.md / envValidator.mjs).
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_STRONG_RANDOM_SESSION_SECRET_MIN_32_CHARS

# [REQUIRED in production|beta] AES-256-GCM key for at-rest field encryption
# (User.mfaSecret/TOTP — backend/utils/fieldEncryption.mjs fails fast if unset/
# wrong length). Must be 64 hex chars (= 32 bytes).
# Generate with: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS_FROM_openssl_rand_hex_32

# [OPTIONAL] bcrypt cost factor (authController.mjs). Keep >= 12 in production.
# NOTE: the code reads BCRYPT_SALT_ROUNDS; SECURITY.md's "BCRYPT_ROUNDS" is doc drift.
BCRYPT_SALT_ROUNDS=12

# [OPTIONAL] Mobile-app API key for CORS-bypass routes (CWE-942). Min 32 chars in prod.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=REPLACE_WITH_STRONG_RANDOM_API_KEY_MIN_32_CHARS

# [OPTIONAL] Policy flag (Equoria-te21j). When truthy, role=admin users must have
# MFA enrolled to use /api/v1/admin/*. Default OFF — enroll admins BEFORE enabling.
# ADMIN_MFA_REQUIRED=false


# =============================================================================
# SESSIONS / COOKIES / CORS
# =============================================================================

# [OPTIONAL] Comma-separated CORS allow-list.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# [OPTIONAL] Cookie domain for subdomain sharing (CWE-384/613). Empty = same-domain.
# Never set to a bare TLD (".com"). Example: COOKIE_DOMAIN=.equoria.com
COOKIE_DOMAIN=

# [OPTIONAL] Session inactivity timeout (ms) and per-user concurrent session cap.
SESSION_TIMEOUT_MS=900000
MAX_CONCURRENT_SESSIONS=5


# =============================================================================
# RATE LIMITING  (backend/middleware/rateLimiting.mjs)
# =============================================================================

# [OPTIONAL] Global limiter window (ms) and max requests per window.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# [OPTIONAL] Max failed auth attempts per window (envValidator recommended var).
AUTH_RATE_LIMIT_MAX=200


# =============================================================================
# REDIS  (distributed rate limiting + query cache)
# =============================================================================
# Rate limiter uses 'redis' via REDIS_URL; cache helper uses 'ioredis' via HOST/PORT/DB.

# [OPTIONAL] Primary connection URL (rediss:// for TLS). Local dev default shown.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TLS=false

# [OPTIONAL] Force the in-memory fallback (skip Redis entirely). "true" disables.
REDIS_DISABLED=false

# [OPTIONAL] Boot-time Redis connect timeout (ms) before falling back to in-memory.
REDIS_BOOT_TIMEOUT_MS=5000


# =============================================================================
# REQUEST BODY SECURITY  (backend/middleware/requestBodySecurity.mjs)
# =============================================================================

# [OPTIONAL] Max JSON nesting depth (anti-DoS). Default 32; out-of-range falls back to 32.
REQUEST_BODY_MAX_DEPTH=32


# =============================================================================
# MONITORING — SENTRY  (backend/config/sentry.mjs, frontend/src/lib/sentry.ts)
# =============================================================================

# [OPTIONAL] Backend error-tracking DSN. Empty = Sentry disabled (safe for dev).
SENTRY_DSN=

# [OPTIONAL] Release tag for Sentry; defaults to equoria@<npm_package_version>.
SENTRY_RELEASE=equoria@1.0.0


# =============================================================================
# EMAIL DELIVERY  (backend/services/emailService.mjs — Equoria-1bvm)
# =============================================================================
# SMTP is REQUIRED in NODE_ENV=production (send throws without it). Beta/test
# capture emails to disk via EMAIL_CAPTURE_FILE instead.

# [REQUIRED in production] SMTP transport (any provider: SES, Resend, Postmark, ...).
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_USERNAME
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD
EMAIL_FROM=noreply@equoria.com
EMAIL_FROM_NAME=Equoria

# [OPTIONAL] Public URL bases embedded in transactional email bodies.
VERIFICATION_URL_BASE=https://app.equoria.com/verify-email
PASSWORD_RESET_URL_BASE=https://app.equoria.com/reset-password
DASHBOARD_URL=https://app.equoria.com/dashboard
SUPPORT_EMAIL=support@equoria.com


# =============================================================================
# AUDIT LOG / RETENTION  (OWASP A09 — Equoria-54qq8)
# =============================================================================

# [OPTIONAL] Days to retain audit_logs rows (nightly purge). Default 90, 7-day floor.
AUDIT_LOG_RETENTION_DAYS=90


# =============================================================================
# GAME / DOMAIN TUNING
# =============================================================================

# [OPTIONAL] Hoof-condition decay cadence in days (farrier loop — Equoria-gg3v).
# Default 30, clamped to a 7-day floor.
HOOF_CONDITION_DECAY_DAYS=30

# [OPTIONAL] Groom config overrides (backend/config/groomConfig.mjs).
# BURNOUT_IMMUNITY_THRESHOLD_DAYS: consecutive-care days before burnout immunity.
# DAILY_BOND_GAIN: per-interaction bond increment.
# BURNOUT_IMMUNITY_THRESHOLD_DAYS=7
# DAILY_BOND_GAIN=2


# =============================================================================
# LOGGING  (backend/utils/logger.mjs)
# =============================================================================

# [OPTIONAL] Winston log level: error | warn | info | http | verbose | debug | silly.
LOG_LEVEL=info


# =============================================================================
# API DOCS  (backend/middleware/swaggerSetup.mjs)
# =============================================================================

# [OPTIONAL] Server URL + version advertised in the generated Swagger document.
API_BASE_URL=http://localhost:3000
API_VERSION=1.2.0

# [OPTIONAL] Base URL the standalone health-check script probes
# (backend/scripts/health-check.mjs). Defaults to http://localhost:3000.
HEALTH_CHECK_URL=http://localhost:3000


# =============================================================================
# SCALING  (backend/utils/clusterManager.mjs — docs/implementation/SCALE-CONFIG.md)
# =============================================================================

# [OPTIONAL] Enable Node.js clustering and worker count when enabled.
CLUSTER_ENABLED=false
WEB_CONCURRENCY=4


# =============================================================================
# FEATURE FLAGS  (backend/config/featureFlags — naming: FF_<SCOPE>_<NAME>)
# =============================================================================
# All [OPTIONAL]. Boolean (true/false/1/0), percentage (0-100), or variant string.
# Any FF_* the code reads is resolved here; only the read ones are listed.
FF_AUTH_PASSWORDLESS_LOGIN=false
FF_BREEDING_EPIGENETICS=true
FF_BREEDING_NEW_UI=0
FF_PERFORMANCE_REDIS_CACHE=false
FF_BETA_FEATURES=
FF_AB_LANDING_PAGE=control
FF_LANDING_PAGE_VARIANT=control


# =============================================================================
# FRONTEND  (Vite — frontend/.env.example; build-time, exposed to the browser)
# =============================================================================

# [OPTIONAL] Backend API base. Empty = relative URLs (monolithic deploy / Vite proxy).
VITE_API_URL=

# [OPTIONAL] Frontend Sentry DSN. Empty = disabled.
VITE_SENTRY_DSN=

# [OPTIONAL] Beta-mode UI toggle.
VITE_BETA_MODE=false

# [TEST/CI ONLY] Dev auth bypass for local E2E. MUST stay false/unset in any
# deployed environment (beta-readiness gate forbids it as readiness evidence).
VITE_DEV_BYPASS_AUTH=false


# =============================================================================
# TEST / CI HARNESS  ([TEST/CI ONLY] — not used by production runtime)
# =============================================================================
# These are set by the Jest/Playwright harness or test .env files, not by
# deployers. Listed for completeness so the var inventory is exhaustive.

# Separate connection string used by the test runner (backend/.env.test).
TEST_DATABASE_URL="postgresql://postgres:REPLACE_WITH_STRONG_PASSWORD@localhost:5432/equoria_test"

# Test-only rate-limit overrides and DB lifecycle toggles.
TEST_RATE_LIMIT_WINDOW_MS=900000
TEST_RATE_LIMIT_MAX_REQUESTS=1000
TEST_DB_RESET_PER_TEST=false
RESET_TEST_DB=false
CLEANUP_TEST_DB=false
SEED_TEST_DATA=false

# Email-capture sink path used by auth E2E tests instead of real SMTP.
EMAIL_CAPTURE_FILE=

# Jest selector / diagnostics toggles (set by npm scripts and jest configs;
# CI and JEST_WORKER_ID are injected by the CI runner / Jest itself, never set
# by a deployer):
#   TEST_TYPE, COVERAGE, BENCHMARK, DETECT_OPEN_HANDLES, SUPPRESS_LOGS,
#   CLEANUP_CACHE, CI, JEST_WORKER_ID
# Load-test knobs (backend/tests/load/run-bulk-foaling-cron.mjs):
#   MARE_COUNT, PARALLEL_SWEEPS
