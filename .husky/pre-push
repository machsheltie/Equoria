#!/usr/bin/env sh
#
# Run backend tests before push.
#
# Equoria-ocn9 (initial fix 2026-04-24, refined post-review same day).
#
# This hook (a) catches obvious regressions before they hit origin and
# (b) is the canonical proof that the code on the branch is in a working
# state. The flags below were arrived at iteratively — DO NOT simplify
# without re-reading the comments.
#
# ---------------- node + Jest flags ----------------
#
#   The suite is run in N sequential SHARDS (see the "run the suite" section
#   below for the full rationale — Equoria-l052p). Each shard is a fresh
#   `node ... jest --runInBand --shard=i/N` process.
#
#   --max-old-space-size=4096 (passed DIRECTLY to node, per shard)
#     Per-shard V8 old-space cap. Each shard's heap starts at baseline and
#     peaks ~1.7 GB (the per-suite leak only accumulates within a single
#     shard, then the process exits and frees everything), so 4 GB is
#     ample headroom. Passed on node's argv because NODE_OPTIONS is silently
#     dropped in the `git push` hook context.
#
#   --runInBand (within each shard)
#     Tests in a shard run sequentially in the SAME process. Combined with
#     running shards one-at-a-time, the ENTIRE suite executes serially:
#     no parallel DB contention, and no mid-run worker recycling (the
#     --maxWorkers=1 --workerIdleMemoryLimit=2048MB approach was tried and
#     reverted 2026-04-29 for non-deterministic FK / Prisma-pool flakes).
#
#   --shard=i/N
#     Jest's deterministic hash partition of the test files. Sharding is
#     ONLY a memory-bounding device here (fresh heap per shard) — NOT
#     parallelism; the shards run sequentially in the loop below.
#
#   --retryTimes=1
#     Handles flaky order-dependent tests that pass in isolation. Retries
#     happen within the same shard process, preserving in-process state.
#
# ---------------- preflight checks ----------------
#
# The hook fails fast with a HELPFUL message in the two scenarios most
# likely to confuse a developer:
#
#   1. Test DB unreachable. Without a probe, the suite would run and
#      hundreds of integration tests would fail with cryptic Prisma errors
#      like "ECONNREFUSED 127.0.0.1:5432". The probe surfaces the actual
#      problem (Postgres) and explicit instructions.
#
#   2. backend/node_modules/jest missing (fresh clone, fresh worktree, or
#      after a deps upgrade). Without a check, the user sees
#      "Cannot find module '.../jest/bin/jest.js'" with no hint that they
#      need to `npm install`.

# Use the repo root regardless of where the hook was invoked from. Prevents
# the `cd backend` line below from breaking when a Git GUI invokes hooks
# from `.husky/` instead of repo root.
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$REPO_ROOT" ]; then
  echo "[pre-push] FATAL: not inside a git working tree" >&2
  exit 1
fi

# Equoria-ocy3 (B2): run doctrine-checks BEFORE the slow backend test suite.
# Mirror what CI's doctrine-gate workflow runs on the merge commit, so a
# --no-verify push still gets caught at the gate (CI catches what the local
# hook missed). Doctrine checks are fast (~2-5 sec); failing fast here saves
# the user from a 10-min test run that would land on a broken doctrine.
# Auto-discovered checks live in scripts/doctrine-checks/check-*.{sh,mjs}.
DOCTRINE_SCRIPT="$REPO_ROOT/scripts/doctrine-checks/run-all.sh"
if [ -x "$DOCTRINE_SCRIPT" ] || [ -f "$DOCTRINE_SCRIPT" ]; then
  printf '[pre-push] Running doctrine checks ...\n'
  if ! bash "$DOCTRINE_SCRIPT"; then
    echo "[pre-push] FATAL: doctrine-checks/run-all.sh failed." >&2
    echo "[pre-push]   Fix the violations above (or add a doctrine-allow marker" >&2
    echo "[pre-push]   if the violation is intentional and documented)." >&2
    exit 1
  fi
fi

cd "$REPO_ROOT/backend" || {
  echo "[pre-push] FATAL: 'backend' directory not found at $REPO_ROOT/backend" >&2
  exit 1
}

# Preflight: jest binary present?
if [ ! -f "node_modules/jest/bin/jest.js" ]; then
  echo "[pre-push] FATAL: backend/node_modules/jest/bin/jest.js not found." >&2
  echo "[pre-push]   This usually means dependencies haven't been installed in this checkout." >&2
  echo "[pre-push]   Run:  cd backend && npm install" >&2
  exit 1
fi

# Preflight: test DB reachable?
# Equoria-ocn9 review: with no probe, doc-only pushes were blocked by a
# wall of cryptic integration-test failures whenever Postgres was down.
# We probe the DATABASE_URL specified in backend/.env.test using the same
# pg client the suite would use. If unreachable, fail fast with a clear
# message naming the actual failure.
#
# Equoria-wnsc (2026-05-06): probe was previously a heredoc inside `$(...)`
# that mis-parsed on Windows Git Bash because of JS backtick template
# literals inside the heredoc body. Moved to a standalone .mjs file so the
# bash parser sees a normal command, not a quoted blob. See
# scripts/preflight/db-probe.mjs for the script.
DB_PROBE_OUTPUT="$(node --experimental-vm-modules "$REPO_ROOT/scripts/preflight/db-probe.mjs" 2>&1)"
DB_PROBE_STATUS=$?
if [ $DB_PROBE_STATUS -ne 0 ]; then
  echo "[pre-push] FATAL: cannot reach the test database." >&2
  echo "[pre-push]   $DB_PROBE_OUTPUT" >&2
  echo "[pre-push] " >&2
  echo "[pre-push]   The pre-push hook runs the full backend integration suite," >&2
  echo "[pre-push]   which requires Postgres on the URL in backend/.env.test." >&2
  echo "[pre-push]   Start Postgres (or check the connection string) and try again." >&2
  exit 1
fi

# Preflight: test DB structurally healthy? (Equoria-urld)
# Checks pending migrations + orphan FK rows before spending ~10 min on Jest.
DB_HEALTH_OUTPUT="$(node --experimental-vm-modules "$REPO_ROOT/scripts/preflight/db-health.mjs" 2>&1)"
DB_HEALTH_STATUS=$?
if [ $DB_HEALTH_STATUS -ne 0 ]; then
  echo "[pre-push] FATAL: test DB inconsistency detected — fix before running the suite." >&2
  echo "[pre-push]   $DB_HEALTH_OUTPUT" >&2
  exit 1
fi

# ---------------- run the suite (sharded) ----------------
#
# Equoria-jcgid (policy): this runs from `backend/` (the `cd` above), so Jest
# uses backend/jest.config.mjs (rootDir: backend, testMatch '**/*.test.mjs').
# That config collects ONLY backend/** tests and CANNOT reach the repo-root
# `tests/` directory. The legacy root-level integration suites under `tests/`
# (e.g. progression / leaderboard / breeds) are therefore intentionally
# EXCLUDED from this pre-push gate. They run via the root jest.config.js
# (`npm test` / CI) where they are scoped-safe against the canonical DB.
# DO NOT change this to run Jest from the repo root (or with the root config):
# doing so would pull the root `tests/` into the gate. If a root integration
# suite ever needs gate coverage, add it under backend/ or give it its own
# dedicated, canonical-safe job — never widen this hook to the root config.
#
# Equoria-l052p: the backend suite leaks ~16-20 MB per test file — diffuse
# (global singletons + native handles + leaked process listeners pin each
# suite's freshly-built module graph so it cannot be GC'd). Run as ONE
# process (the previous bare --runInBand) it compounded to 7 GB+ across the
# ~470 suites, triggering GC thrash (per-suite time 3s -> 30s+) and a
# multi-HOUR effective hang that pinned the developer's machine.
#
# Worker recycling (--maxWorkers=1 --workerIdleMemoryLimit) was tried and
# reverted 2026-04-29 because recycling mid-run disrupts the Prisma pool and
# produces non-deterministic FK / test-isolation flakes (see git history).
#
# Fix: run the suite in N sequential SHARDS, each a FRESH jest process. The
# heap resets to baseline between shards, so memory stays bounded (~1.7 GB
# per shard, well under the 4 GB cap) and never thrashes. Execution stays
# strictly serial — one shard process at a time, --runInBand within each —
# so there is NO parallel DB contention and NO mid-run worker recycle.
# Verified: shard 1/8 = 80 suites / 1471 tests in ~79s, heap peak 1.7 GB.
SHARD_COUNT=8
SHARD_FAILED=0
for i in $(seq 1 "$SHARD_COUNT"); do
  echo "[pre-push] Running backend test shard ${i}/${SHARD_COUNT} ..."
  node \
    --max-old-space-size=4096 \
    --experimental-vm-modules \
    node_modules/jest/bin/jest.js \
    --runInBand \
    --shard="${i}/${SHARD_COUNT}" \
    --retryTimes=1
  SHARD_EC=$?
  if [ "$SHARD_EC" -ne 0 ]; then
    echo "[pre-push] FATAL: backend test shard ${i}/${SHARD_COUNT} failed (exit ${SHARD_EC})." >&2
    SHARD_FAILED=1
    break
  fi
done

if [ "$SHARD_FAILED" -ne 0 ]; then
  exit 1
fi
