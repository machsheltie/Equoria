# Backend API URL
# Leave unset for monolithic production deploy (relative URLs work automatically).
# Development (through Vite proxy): leave unset or set to http://localhost:3000
# Split deploy (frontend on CDN, backend elsewhere): https://api.yourdomain.com
VITE_API_URL=

# Sentry error tracking (leave empty to disable)
# Get your DSN at https://sentry.io → Project → Settings → Client Keys
VITE_SENTRY_DSN=
