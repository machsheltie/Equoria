generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  /// Unique identifier for each user
  id               String            @id @default(uuid())
  /// Username used for login or display
  username         String            @unique
  /// Email address (must be unique)
  email            String            @unique
  /// Hashed password
  password         String
  /// Timestamp of last password change. CWE-613 mitigation: tokens with iat older than
  /// this value are rejected by authenticateToken. Null = no constraint (existing users
  /// who have never rotated their password — legacy sessions remain valid until natural expiry).
  passwordChangedAt DateTime?
  /// First and last name for display purposes
  firstName        String
  lastName         String
  /// Date of birth — collected at registration for COPPA age-gate enforcement
  /// (Equoria-iqzn). Server computes real-calendar age and rejects under-13
  /// registrations BEFORE this row is created, so persisted rows are always
  /// >= 13. Nullable for legacy accounts created before the age gate existed.
  /// Treated as sensitive PII: redacted from audit/request logs.
  dateOfBirth      DateTime?
  /// In-game currency (or balance)
  money            Int               @default(1000)
  /// Current level of the user
  level            Int               @default(1)
  /// Experience points toward next level
  xp               Int               @default(0)
  /// User role for access control
  role             String            @default("user")
  /// JSON object for customizable settings (theme, preferences, etc.)
  settings         Json              @default("{}")
  /// Grace period start date for groom salary payments
  groomSalaryGracePeriod DateTime?
  /// Email verification status
  emailVerified    Boolean           @default(false)
  emailVerifiedAt  DateTime?
  /// TOTP MFA (OWASP A07, Equoria-2vwwh). Opt-in. mfaSecret is the base32 TOTP
  /// shared secret. At-rest encryption is NOT yet applied (no encryption util
  /// exists in the codebase) — tracked as a follow-up. mfaRecoveryCodes is a
  /// JSON array of { codeHash, usedAt } objects; codes are bcrypt-hashed and
  /// single-use. mfaEnabled gates the login challenge.
  mfaSecret        String?
  mfaEnabled       Boolean           @default(false)
  mfaRecoveryCodes Json?
  /// Timestamps
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  groomAssignments        GroomAssignment[]
  groomSalaryPayments     GroomSalaryPayment[]
  groomPerformanceRecords GroomPerformanceRecord[]
  grooms                  Groom[]
  horses                  Horse[]
  riders                  Rider[]
  riderAssignments        RiderAssignment[]
  trainers                Trainer[]
  trainerAssignments      TrainerAssignment[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  transactions            UserTransaction[]
  shows                   Show[]
  xpEvents                XpEvent[]
  facilities              Facility[]
  emailVerificationTokens EmailVerificationToken[]
  forumThreads            ForumThread[]            @relation("ForumThreads")
  forumPosts              ForumPost[]              @relation("ForumPosts")
  sentMessages            DirectMessage[]          @relation("SentMessages")
  receivedMessages        DirectMessage[]          @relation("ReceivedMessages")
  clubsLed                Club[]                   @relation("ClubsLed")
  clubMemberships         ClubMembership[]         @relation("ClubMemberships")
  candidacies             ClubCandidate[]          @relation("ElectionCandidacies")
  ballots                 ClubBallot[]             @relation("CastBallots")
  horsesSold              HorseSale[]              @relation("HorseSalesSold")
  horsesBought            HorseSale[]              @relation("HorseSalesBought")
  showsCreated            Show[]                   @relation("ShowCreator")
  showEntries             ShowEntry[]              @relation("ShowEntries")
  staffMarketplaceStates  StaffMarketplaceState[]
  notifications             Notification[]
  rankSnapshots             UserRankSnapshot[]

  @@index([email])
  @@index([emailVerified])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  isRead    Boolean  @default(false)
  payload   Json
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
}

model Breed {
  /// Unique identifier for each breed
  id                  Int     @id @default(autoincrement())
  /// Name of the breed (unique constraint required for ON CONFLICT upserts)
  name                String  @unique
  /// Description of the breed
  description         String?
  /// Optional default trait associated with the breed
  defaultTrait        String?
  /// JSONB containing rating_profiles (conformation, gaits, gaited config) and temperament_weights
  breedGeneticProfile Json?
  horses              Horse[]

  @@map("breeds")
}

model Stable {
  /// Unique identifier for each stable
  id       Int     @id @default(autoincrement())
  /// Name of the stable
  name     String
  /// Location of the stable
  location String?
  horses   Horse[]

  @@map("stables")
}

model Horse {
  /// Unique identifier for each horse
  id                      Int                   @id @default(autoincrement())
  /// Name of the horse
  name                    String
  /// Sex of the horse
  sex                     String
  /// Date of birth
  dateOfBirth             DateTime              @db.Date
  /// Foreign keys
  breedId                 Int?
  stableId                Int?
  /// Genetics and appearance
  genotype                Json?
  phenotypicMarkings      Json?
  /// Coat color genetics (Epic 31E)
  colorGenotype           Json?                 // Allele pairs per locus: { E_Extension: "E/e", ... }
  phenotype               Json?                 // Calculated phenotype: { color, shade, markings, ... }
  finalDisplayColor       String?
  shade                   String?
  imageUrl                String?               @default("/images/samplehorse.JPG")
  /// Traits and characteristics
  trait                   String?
  temperament             String?
  personality             String?
  /// Epigenetic trait flags for horses under 3 years old (PERMANENT once assigned)
  epigeneticFlags         String[]              @default([])
  /// Temporary / environment-triggered epigenetic flags (Equoria-yzqhj.5).
  /// JSON array of { flag: string, expiresAt: ISO-string, source: string }.
  /// Expired entries are swept daily by the temporaryFlagExpiry cron.
  temporaryEpigeneticFlags Json                 @default("[]")
  /// Base stats
  precision               Int?                  @default(0)
  strength                Int?                  @default(0)
  speed                   Int?                  @default(0)
  agility                 Int?                  @default(0)
  endurance               Int?                  @default(0)
  intelligence            Int?                  @default(0)
  /// Additional competition stats
  stamina                 Int?                  @default(0)
  balance                 Int?                  @default(0)
  boldness                Int?                  @default(0)
  flexibility             Int?                  @default(0)
  obedience               Int?                  @default(0)
  focus                   Int?                  @default(0)
  /// Financial and breeding
  totalEarnings           Int?                  @default(0)
  sireId                  Int?
  damId                   Int?
  studStatus              String?               @default("Not at Stud")
  studFee                 Int?                  @default(0)
  lastBredDate            DateTime?             @db.Date
  /// In-foal state (Phase B — feed-system pregnancy mechanic)
  inFoalSinceDate         DateTime?
  pregnancySireId         Int?
  pregnancyFeedingsByTier Json                  @default("{}")
  pendingFoalName         String?
  pendingFoalBreedId      Int?
  forSale                 Boolean?              @default(false)
  salePrice               Int?                  @default(0)
  /// Health and care
  healthStatus            String?               @default("Excellent")
  lastVettedDate          DateTime?             @default(now()) @db.Date
  bondScore               Int?                  @default(0)
  stressLevel             Int?                  @default(0)
  /// Groom bonding and burnout prevention
  daysGroomedInARow       Int?                  @default(0)
  burnoutStatus           String?               @default("none")
  /// Foal task logging and streak tracking
  taskLog                 Json?
  consecutiveDaysFoalCare Int?                  @default(0)
  lastGroomed             DateTime?
  /// Game mechanics
  tack                    Json?                 @default("{}")
  age                     Int?
  userId                  String?
  trainingCooldown        DateTime?
  earnings                Decimal?              @default(0) @db.Decimal(10, 2)
  rider                   Json?
  disciplineScores        Json?
  epigeneticModifiers     Json?                 @default("{\"hidden\": [], \"negative\": [], \"positive\": []}")
  /// Ultra-rare and exotic traits with acquisition metadata
  ultraRareTraits         Json?                 @default("{\"ultraRare\": [], \"exotic\": []}")
  /// Conformation scoring (1-100 scale per body region)
  conformationScores      Json?                 @default("{\"head\": 20, \"neck\": 20, \"shoulders\": 20, \"back\": 20, \"legs\": 20, \"hooves\": 20, \"topline\": 20, \"hindquarters\": 20, \"overallConformation\": 20}")
  /// Gait quality scores (permanent, generated at birth)
  gaitScores              Json?
  /// Horse XP System
  horseXp                 Int?                  @default(0)
  availableStatPoints     Int?                  @default(0)
  /// Farrier fields
  lastFarrierDate         DateTime?
  hoofCondition           String?               @default("good")
  lastShod                DateTime?
  /// Feed Shop fields (redesign 2026-04-29)
  equippedFeedType        String?
  lastFedDate             DateTime?
  /// Conformation show title progression (Epic 31F-3)
  titlePoints             Int                   @default(0)
  currentTitle            String?
  breedingValueBoost      Float                 @default(0.0)
  /// Timestamps
  createdAt               DateTime?             @default(now())
  updatedAt               DateTime?             @updatedAt
  competitionResults      CompetitionResult[]
  foalActivities          FoalActivity[]
  foalDevelopment         FoalDevelopment?      @relation("FoalDevelopmentFoal")
  foalTrainingHistory     FoalTrainingHistory[]
  groomAssignments        GroomAssignment[]
  groomInteractions       GroomInteraction[]
  groomPerformanceRecords GroomPerformanceRecord[]
  horseXpEvents           HorseXpEvent[]
  traitHistoryLogs        TraitHistoryLog[]
  milestoneTraitLogs      MilestoneTraitLog[]
  ultraRareTraitEvents    UltraRareTraitEvent[]
  groomHorseSynergies     GroomHorseSynergy[]
  groomAssignmentLogs     GroomAssignmentLog[]
  riderAssignments        RiderAssignment[]
  trainerAssignments      TrainerAssignment[]
  breed                   Breed?                @relation(fields: [breedId], references: [id])
  dam                     Horse?                @relation("DamLineage", fields: [damId], references: [id])
  damOffspring            Horse[]               @relation("DamLineage")
  sire                    Horse?                @relation("SireLineage", fields: [sireId], references: [id])
  sireOffspring           Horse[]               @relation("SireLineage")
  stable                  Stable?               @relation(fields: [stableId], references: [id])
  user                    User?                 @relation(fields: [userId], references: [id])
  trainingLogs            TrainingLog[]
  horseSales              HorseSale[]
  showEntries             ShowEntry[]

  @@index([userId])
  @@index([breedId])
  @@index([stableId])
  @@map("horses")
}

model Groom {
  /// Unique identifier for each groom
  id                Int                @id @default(autoincrement())
  /// Name of the groom
  name              String
  /// Speciality area
  speciality        String
  /// Experience points for progression system
  experience        Int                @default(0)
  /// Current level (1-10)
  level             Int                @default(1)
  /// Skill level
  skillLevel        String             @default("novice")
  /// Canonical groom personality (gentle | energetic | patient | strict).
  /// Used by groom synergy (Epic 31D-4), temperament compatibility,
  /// groomPersonalityEffects, getTemperamentGroomSynergy(), and
  /// trait-development bonuses. THIS is the user-facing personality.
  /// Equoria-4ukc: consolidation deferred — semantically distinct from
  /// epigeneticInfluenceType (see below).
  personality       String
  /// Epigenetic trait-influence type (balanced | calm | energetic | gentle |
  /// methodical | confident | ...). Used by enhancedMilestoneEvaluation,
  /// groomPersonalityTraits, flagAssignmentEngine, and the trait-influence
  /// trait-discovery pipeline. Distinct semantic from `personality`:
  /// `personality` drives interaction synergy/care quality; this field drives
  /// which epigenetic traits a groom imprints onto a foal. Defaults to
  /// 'balanced' so legacy grooms have a safe no-op behavior.
  /// Equoria-4ukc: kept separate after audit — both fields are live and read
  /// by independent subsystems.
  epigeneticInfluenceType  String             @default("balanced")
  /// Bonus trait map for rare trait acquisition (JSON object with trait names and probability bonuses)
  bonusTraitMap     Json               @default("{}")
  /// Rare trait booster perks for ultra-rare and exotic traits (JSON object with perk definitions)
  rareTraitPerks    Json               @default("{}")
  /// Session rate (per session, not hourly)
  sessionRate       Decimal            @default(15.0) @db.Decimal(10, 2)
  /// Availability schedule
  availability      Json               @default("{}")
  /// Biography
  bio               String?
  /// Image URL
  imageUrl          String?
  /// Active status
  isActive          Boolean            @default(true)
  /// Show-handling skill rating used by Epic 31F conformation show scoring
  /// (handler weight: 20%). Values: novice | competent | skilled | expert | master.
  /// Mapped to a 0-100 score in conformationShowService.SHOW_HANDLING_SKILL_SCORES.
  /// Backed by migration 20260403000000_add_groom_show_handling_skill. The DB
  /// column name is the camelCase string "showHandlingSkill" (matching the
  /// migration SQL), so no @map is required.
  showHandlingSkill String             @default("novice")
  /// Hire date
  hiredDate         DateTime           @default(now())
  /// Career progression tracking
  careerWeeks       Int                @default(0)
  /// Retirement status
  retired           Boolean            @default(false)
  /// Reason for retirement
  retirementReason  String?
  /// When the groom retired
  retirementTimestamp DateTime?
  /// User association
  userId            String?
  /// Timestamps
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  groomAssignments    GroomAssignment[]
  groomInteractions   GroomInteraction[]
  groomSalaryPayments GroomSalaryPayment[]
  groomPerformanceRecords GroomPerformanceRecord[]
  groomMetrics        GroomMetrics?
  traitHistoryLogs    TraitHistoryLog[]
  milestoneTraitLogs  MilestoneTraitLog[]
  ultraRareTraitEvents UltraRareTraitEvent[]
  groomHorseSynergies GroomHorseSynergy[]
  groomAssignmentLogs GroomAssignmentLog[]
  groomTalentSelections GroomTalentSelections?
  retiredGroomLegacies GroomLegacyLog[] @relation("RetiredGroomLegacy")
  legacyGroomMentors  GroomLegacyLog[] @relation("LegacyGroomMentor")
  user                User?              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([level])
  @@index([experience])
  @@index([careerWeeks])
  @@index([retired])
  @@index([retired, careerWeeks])
  @@map("grooms")
}

model GroomAssignment {
  /// Unique identifier for each assignment
  id                Int                @id @default(autoincrement())
  /// Assignment period
  startDate         DateTime           @default(now())
  endDate           DateTime?
  /// Status flags
  isActive          Boolean            @default(true)
  isDefault         Boolean            @default(false)
  /// Priority level (1-5)
  priority          Int                @default(1)
  /// Bond score between groom and foal (0-100)
  bondScore         Int                @default(0)
  /// Notes
  notes             String?
  /// Foreign keys
  foalId            Int
  groomId           Int
  userId            String?
  /// Timestamps
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  foal              Horse              @relation(fields: [foalId], references: [id], onDelete: Cascade)
  groom             Groom              @relation(fields: [groomId], references: [id], onDelete: Cascade)
  user              User?              @relation(fields: [userId], references: [id])
  groomInteractions GroomInteraction[]

  @@unique([foalId, groomId, isActive])
  @@index([foalId])
  @@index([groomId])
  @@map("groom_assignments")
}

model GroomInteraction {
  /// Unique identifier for each interaction
  id              Int              @id @default(autoincrement())
  /// Type of interaction
  interactionType String
  /// Duration in minutes
  duration        Int
  /// Bonding change (-10 to +10)
  bondingChange   Int              @default(0)
  /// Stress change (-10 to +10)
  stressChange    Int              @default(0)
  /// Quality of interaction
  quality         String           @default("good")
  /// Notes
  notes           String?
  /// Cost
  cost            Decimal          @default(0.0) @db.Decimal(10, 2)
  /// Task type for milestone evaluation
  taskType        String?
  /// Quality score for milestone evaluation (0.0-1.0)
  qualityScore    Float?           @default(0.75)
  /// Milestone window identifier for grouping interactions
  milestoneWindowId String?
  /// 31D-4: Temperament-groom synergy modifier applied to this interaction (e.g. 0.25 = +25%, -0.15 = -15%)
  synergyModifier Float?           @default(0)
  /// Foreign keys
  foalId          Int
  groomId         Int
  assignmentId    Int?
  /// Timestamps
  timestamp       DateTime         @default(now())
  createdAt       DateTime         @default(now())
  assignment      GroomAssignment? @relation(fields: [assignmentId], references: [id])
  foal            Horse            @relation(fields: [foalId], references: [id], onDelete: Cascade)
  groom           Groom            @relation(fields: [groomId], references: [id], onDelete: Cascade)

  @@index([foalId])
  @@index([groomId])
  @@map("groom_interactions")
}

model Show {
  /// Unique identifier for each show
  id                 Int                 @id @default(autoincrement())
  /// Name of the show
  name               String              @unique
  /// Discipline
  discipline         String
  /// Level requirements
  levelMin           Int
  levelMax           Int
  /// Financial details
  entryFee           Int
  prize              Int
  /// Schedule
  runDate            DateTime
  /// Host user
  hostUserId         String?
  /// Show lifecycle status (BA-1)
  status             ShowStatus          @default(open)
  /// When the show was opened for entries (BA-1)
  openDate           DateTime?
  /// When the show stops accepting entries — openDate + 7 days (BA-1)
  closeDate          DateTime?
  /// When the overnight execution completed (BA-1)
  executedAt         DateTime?
  /// User who created this show (BA-1)
  createdByUserId    String?
  /// Club that created this show (BA-1)
  createdByClubId    Int?
  /// Optional description (BA-2)
  description        String?
  /// Max entries allowed (BA-2)
  maxEntries         Int?
  /// Show type: 'ridden' (default discipline scoring), 'conformation', or 'parade' (presentation scoring)
  showType           String              @default("ridden")
  /// Timestamps
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  competitionResults CompetitionResult[]
  entries            ShowEntry[]
  hostUser           User?               @relation(fields: [hostUserId], references: [id])
  createdByUser      User?               @relation("ShowCreator", fields: [createdByUserId], references: [id])

  @@index([status])
  @@index([closeDate])
  @@map("shows")
}

model CompetitionResult {
  /// Unique identifier for each result
  id         Int      @id @default(autoincrement())
  /// Competition details
  score      Decimal  @db.Decimal(10, 2)
  placement  String?
  discipline String
  runDate    DateTime
  showName   String
  /// Rewards
  prizeWon   Decimal? @default(0) @db.Decimal(10, 2)
  statGains  Json?
  /// Foreign keys
  horseId    Int
  showId     Int
  /// Timestamps
  createdAt  DateTime @default(now())
  horse      Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)
  show       Show     @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@unique([showId, horseId])
  @@index([horseId, score])
  @@map("competition_results")
}

model TrainingLog {
  /// Unique identifier for each training session
  id         Int      @id @default(autoincrement())
  /// Training details
  discipline String
  trainedAt  DateTime @default(now())
  /// Foreign key
  horseId    Int
  horse      Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@map("training_logs")
}

model FoalDevelopment {
  /// Unique identifier for each foal development record
  id                  Int       @id @default(autoincrement())
  /// Development progress
  currentDay          Int       @default(0)
  bondingLevel        Int       @default(50)
  bondScore           Int       @default(0)
  stressLevel         Int       @default(20)
  completedActivities Json      @default("{}")
  /// BB-1: Age-based stage (derived from Horse.dateOfBirth but cached here)
  ageStage            AgeStage  @default(newborn)
  /// BB-3: Milestone tracking (firstBondLevel25, firstBondLevel50, etc.)
  completedMilestones Json      @default("{}")
  /// BB-4: Whether the foal window is still open
  isActive            Boolean   @default(true)
  /// Last interaction timestamp (for WYAG feed)
  lastInteractionAt   DateTime?
  /// Foreign key — foalId maps to horse.id for the foal
  foalId              Int       @unique
  horseId             Int?
  /// Timestamps
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  foal                Horse     @relation("FoalDevelopmentFoal", fields: [foalId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@map("foal_development")
}

model FoalActivity {
  /// Unique identifier for each foal activity
  id            Int      @id @default(autoincrement())
  /// Activity details
  day           Int
  activityType  String
  outcome       String
  bondingChange Int
  stressChange  Int
  description   String
  /// Stream-source discriminator (Equoria-8yhe3). ENFORCES the disjointness of
  /// the two FoalActivity writers so the taskLog-count derivation can never
  /// silently absorb a foreign stream. Values: 'groom_interaction' (the
  /// taskLog-driving groom path) and 'enrichment_activity' (the legacy foal
  /// enrichment-day system, which does NOT feed taskLog). Nullable for legacy
  /// pre-8yhe3 rows: a NULL source is treated as 'groom_interaction' by the
  /// derivation (the only writer that wrote canonical rows before this column
  /// existed was recordInteraction). See foalActivityStore.mjs.
  source        String?
  /// Foreign key
  foalId        Int
  /// Timestamps
  createdAt     DateTime @default(now())
  foal          Horse    @relation(fields: [foalId], references: [id], onDelete: Cascade)

  @@index([foalId, source])
  @@map("foal_activities")
}

model FoalTrainingHistory {
  /// Unique identifier for each training history record
  id           String   @id @default(uuid())
  /// Training details
  day          Int
  activity     String
  outcome      String
  bondChange   Int      @default(0)
  stressChange Int      @default(0)
  /// Foreign key
  horseId      Int
  /// Timestamps
  timestamp    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  horse        Horse    @relation(fields: [horseId], references: [id], onDelete: Cascade)

  @@index([horseId])
  @@index([day])
  @@index([timestamp])
  @@index([horseId, day])
  @@map("foal_training_history")
}

model XpEvent {
  /// Unique identifier for each XP event
  id        Int      @id @default(autoincrement())
  /// XP details
  amount    Int
  reason    String
  /// Foreign key
  userId    String
  /// Timestamps
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
  @@index([userId, timestamp])
  @@map("xp_events")
}

model RefreshToken {
  /// Unique identifier for each refresh token
  id             Int       @id @default(autoincrement())
  /// SHA-256 hash (hex) of the refresh token. Raw token is never persisted —
  /// Equoria-uy73 (2026-04-23) converted this column from raw JWT to hash so a
  /// DB read leak does not grant active sessions. Existing rows were purged on
  /// migration; users re-login after deploy.
  tokenHash      String    @unique @db.VarChar(64)
  /// User who owns this token
  userId         String
  /// Token family ID for rotation tracking
  familyId       String?
  /// Token expiration date
  expiresAt      DateTime
  /// Whether token is currently active
  isActive       Boolean   @default(true)
  /// Whether token has been invalidated due to security breach
  isInvalidated  Boolean   @default(false)
  /// Last activity timestamp (for session timeout tracking - CWE-613)
  lastActivityAt DateTime?
  /// Timestamps
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([lastActivityAt])
  @@index([familyId])
  @@index([isActive, isInvalidated])
  @@index([familyId, isActive, isInvalidated])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  /// Unique identifier for each email verification token
  id         Int       @id @default(autoincrement())
  /// SHA-256 hash (hex) of the 256-bit cryptographic verification token. Raw
  /// token is emailed to the user and never persisted — Equoria-uy73
  /// (2026-04-23) mirrored the password-reset hashing pattern so a DB read
  /// leak cannot be used to verify arbitrary accounts. Outstanding rows were
  /// purged on migration; users must re-request verification.
  tokenHash  String    @unique @db.VarChar(64)
  /// User who owns this token
  userId     String
  /// Email address being verified
  email      String    @db.VarChar(255)
  /// Token expiration date (24 hours from creation)
  expiresAt  DateTime
  /// Timestamp when token was created
  createdAt  DateTime  @default(now())
  /// Timestamp when token was used (null if not yet used)
  usedAt     DateTime?
  /// IP address from which verification was initiated (audit trail)
  ipAddress  String?   @db.VarChar(45)
  /// User agent from which verification was initiated (audit trail)
  userAgent  String?   @db.Text
  /// Relation to user
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([email])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  tokenHash String    @unique
  userId    String
  email     String
