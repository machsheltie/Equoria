// ── Equoria-9wby: Persistent CronRunLog ────────────────────────────────────────
// Cross-restart history of cron job executions. Complements the in-memory
// heartbeat (CronJobService.heartbeats) added in Equoria-0elk by giving
// /api/admin/cron/health a queryable last-N runs view per job that survives
// process restarts.
//
// Written by CronJobService.runWithHeartbeat() on every cycle (success + error)
// — one row per cycle, status = 'success' | 'error'. Aggregated summary
// counters (horsesProcessed, birthdaysFound, etc.) come from each job
// handler's return payload via summarizeResult() — see backend/services/cronJobs.mjs.

model CronRunLog {
  id                    Int      @id @default(autoincrement())
  jobName               String
  startedAt             DateTime
  finishedAt            DateTime?
  /// 'success' | 'error'
  status                String
  horsesProcessed       Int?
  birthdaysFound        Int?
  milestonesEvaluated   Int?
  electionsOpened       Int?
  electionsClosed       Int?
  errorsCount           Int?
  errorMessage          String?
  /// Full handler summary payload as JSONB for forward-compat (new counters
  /// surface here without a schema change).
  summary               Json?
  createdAt             DateTime @default(now())

  @@index([jobName, startedAt(sort: Desc)])
  @@index([status])
  @@map("cron_run_logs")
}

// ── Equoria-jw10w: DB-backed security audit trail (OWASP A09) ──────────────────
// Tamper-evident, queryable, retained audit trail for sensitive mutating
// operations. `userId` is a SOFT reference (no FK relation) on purpose: audit
// records must survive user deletion for forensic/compliance reasons — a
// cascading delete would let an attacker erase their own trail by deleting
// their account. Written best-effort/fail-soft by storeAuditLog(); an audit
// write failure must never break the underlying request.
model AuditLog {
  id           Int      @id @default(autoincrement())
  /// Soft reference to User.id (uuid). Nullable for unauthenticated events
  /// (e.g. failed login). NOT a Prisma relation by design (see above).
  userId       String?
  /// Operation classifier, e.g. 'authentication', 'transaction', 'breeding',
  /// 'training', 'admin_operation', or 'mutation' for the generic global path.
  action       String
  /// Logical resource touched, derived from the request path's first segment.
  resource     String?
  /// Resource identifier when the route carries one (best-effort).
  resourceId   String?
  method       String
  path         String
  statusCode   Int
  ip           String?
  userAgent    String?
  /// true when statusCode < 400.
  success      Boolean
  /// Sanitized request context (body/params/query with secrets redacted).
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([action])
  @@map("audit_logs")
}
