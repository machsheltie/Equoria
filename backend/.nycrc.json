{
  "all": true,
  "check-coverage": true,
  "reporter": [
    "text",
    "text-summary",
    "html",
    "lcov",
    "json",
    "json-summary",
    "cobertura"
  ],
  "include": ["**/*.mjs", "**/*.js"],
  "exclude": [
    "coverage/**",
    "node_modules/**",
    "tests/**",
    "test/**",
    "**/*.test.mjs",
    "**/*.test.js",
    "**/*.spec.mjs",
    "**/*.spec.js",
    "jest.config.js",
    "jest.setup.mjs",
    "eslint.config.mjs",
    "babel.config.js",
    "server.mjs",
    "scripts/**",
    "seed/**",
    "migrations/**",
    "dist/**",
    "build/**",
    "docs/**",
    "examples/**",
    "coverage-security/**",
    "augment-vip-main/**",
    "mcp-server-mas-sequential-thinking/**",
    ".prettierrc.mjs",
    "jest.config.*.mjs",
    "test-connection.mjs",
    "test-postgres-connection.mjs",
    "init-databases.mjs",
    "init-test-database.mjs",
    "seed-test-data.mjs",
    "check-underscore-imports.mjs",
    "fix-breed-relations.mjs",
    "fix-mock-imports.mjs",
    "fix-mock-imports-v2.mjs",
    "fix-unstable-mocks.mjs",
    "tmp-auth-check.mjs",
    "verify-test-db.mjs"
  ],
  "branches": 80,
  "lines": 85,
  "functions": 80,
  "statements": 85,
  "watermarks": {
    "lines": [80, 95],
    "functions": [80, 95],
    "branches": [80, 95],
    "statements": [80, 95]
  },
  "report-dir": "./coverage",
  "temp-dir": "./coverage/.nyc_output",
  "cache": true,
  "cache-dir": "./coverage/.nyc_cache",
  "instrument": true,
  "source-map": true,
  "produce-source-map": true,
  "skip-full": false,
  "skip-empty": false,
  "clean": true
}
