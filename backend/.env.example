# Server Configuration
PORT=3000
NODE_ENV=development

# ============================================
# MONITORING — SENTRY
# ============================================
# Error tracking and performance monitoring.
# Leave empty to disable Sentry (safe for local dev).
# Get your DSN at https://sentry.io → Project → Settings → Client Keys
SENTRY_DSN=

# Database Configuration
# SECURITY: Use strong passwords (32+ characters, mix of letters/numbers/symbols)
# Generate with: openssl rand -base64 32
DATABASE_URL="postgresql://postgres:REPLACE_WITH_STRONG_PASSWORD@localhost:5432/equoria"

# ============================================
# REDIS CONFIGURATION
# ============================================
# Redis is used for two purposes:
# 1. Distributed rate limiting (production-ready)
# 2. Query caching (implemented but not enabled - awaiting performance testing)
#
# ARCHITECTURE:
# - Rate limiting uses 'redis' package via REDIS_URL
# - Cache helper uses 'ioredis' package via REDIS_HOST/PORT/DB
# - Both clients close gracefully in server.mjs shutdown handler
#
# LOCAL DEVELOPMENT:
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TLS=false
#
# PRODUCTION EXAMPLES:
# AWS ElastiCache:
# REDIS_URL=rediss://your-elasticache-endpoint.cache.amazonaws.com:6380
# REDIS_PASSWORD=your-redis-password
# REDIS_TLS=true
#
# Redis Cloud / Upstash:
# REDIS_URL=redis://default:your-password@your-host:6379
# REDIS_PASSWORD=your-password
# REDIS_TLS=false
#
# Railway Redis:
# REDIS_URL=redis://default:password@host:port
#
# NOTE: If both REDIS_URL and REDIS_HOST are set, cacheHelper uses REDIS_HOST
# RECOMMENDATION: Use REDIS_URL for consistency across both clients
#
# RATE_LIMIT_REQUIRE_REDIS (Equoria-4kfbh) — startup fail-fast on missing Redis.
# When 'true' AND NODE_ENV is a deployable env (production/beta), the process
# REFUSES TO START if Redis is unreachable within REDIS_BOOT_TIMEOUT_MS instead
# of silently falling back to per-process in-memory rate limiting. In a
# multi-node deployment that silent fallback multiplies every per-user/per-IP
# cap by node count and neuters the auth brute-force limiter cluster-wide — a
# fail-OPEN on a critical security control. SET THIS TO 'true' for any
# multi-node / horizontally-scaled production deploy. Leave unset/'false' for a
# single-node deploy that can tolerate per-process limiting. Has no effect in
# development/test or when REDIS_DISABLED=true.
RATE_LIMIT_REQUIRE_REDIS=false

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT Authentication
# SECURITY: REQUIRED - minimum 32 characters.
# In production/beta, backend/config/config.mjs fails fast at startup if
# JWT_SECRET or JWT_REFRESH_SECRET is missing, a known placeholder, or shorter
# than 32 chars (see backend/utils/runtimeSecretPolicy.mjs).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Example: 84a261776495d2d6284513e6c24970bd424d9a4982d2c634c63a4e9d0cd49bb3
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# SECURITY: REQUIRED - minimum 32 characters. Signs/verifies refresh tokens.
# Must be DIFFERENT from JWT_SECRET. Same fail-fast startup validation applies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_RANDOM_SECRET_MIN_32_CHARS

# JWT key rotation overlap window (Equoria-gjdj, see
# docs/architecture/adr-009-jwt-secret-rotation-keyring.md).
# OPTIONAL — leave UNSET in normal operation. Only set DURING a secret
# rotation: put the OLD JWT_SECRET / JWT_REFRESH_SECRET value here so tokens
# signed with the old key still verify until they expire. Tokens are ALWAYS
# signed with the current secret; *_PREVIOUS is verify-only. Unset again once
# the longest token lifetime has elapsed to close the window.
# JWT_SECRET_PREVIOUS=
# JWT_REFRESH_SECRET_PREVIOUS=

# SESSION_SECRET — referenced by SECURITY.md as a required production setting
# and by backend/utils/envValidator.mjs as a recommended security variable.
# SECURITY: set a strong 32+ char random value before production deployment.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_STRONG_RANDOM_SESSION_SECRET_MIN_32_CHARS

# FIELD_ENCRYPTION_KEY (Equoria-yi13v) — AES-256-GCM key for at-rest
# encryption of sensitive DB fields (currently User.mfaSecret / TOTP).
# REQUIRED in production/beta: backend/utils/fieldEncryption.mjs fails fast
# (no plaintext fallback) if this is unset or not 32 bytes when running with
# NODE_ENV=production or beta. Must be 64 hex chars (= 32 bytes).
# Generate with: openssl rand -hex 32
#   (or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
FIELD_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS_FROM_openssl_rand_hex_32

# ADMIN_MFA_REQUIRED (Equoria-te21j) — optional policy. When truthy
# (true/1/yes/on), accounts with role=admin MUST have MFA enrolled+enabled
# to use admin-scoped routes (/api/v1/admin/*); otherwise those routes return
# 403 "Admin MFA required". Default OFF (unset) — does NOT lock out existing
# admins on deploy. ROLLOUT: have every admin complete
# POST /api/v1/auth/mfa/enroll then /mfa/verify-enrollment BEFORE setting this
# to true, or they will be blocked from admin routes (login itself is
# unaffected, and they can still enroll via the authenticated MFA endpoints).
# ADMIN_MFA_REQUIRED=false

# Cookie Configuration (CWE-384, CWE-613)
# COOKIE_DOMAIN: Domain for cookie sharing across subdomains
# - Leave empty (default) for same-domain cookies (app and API on same domain)
# - Set to '.yourdomain.com' for subdomain sharing (app.yourdomain.com, api.yourdomain.com)
# Examples:
# - Same domain: COOKIE_DOMAIN= (empty, default)
# - Subdomain sharing: COOKIE_DOMAIN=.equoria.com
# SECURITY: Never set to top-level domain (.com) - security risk
COOKIE_DOMAIN=

# Optional: Logging Configuration
LOG_LEVEL=info

# Optional: Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: Security Configuration
# BCRYPT_SALT_ROUNDS is the canonical bcrypt cost-factor env var the code reads
# (backend/modules/auth/controllers/authController.mjs). SECURITY.md historically
# names this "BCRYPT_ROUNDS" — that is documentation drift; the variable the
# application actually consumes is BCRYPT_SALT_ROUNDS.
# SECURITY: keep >= 12 in production.
BCRYPT_SALT_ROUNDS=12
JWT_ACCESS_TOKEN_EXPIRY=24h
JWT_REFRESH_TOKEN_EXPIRY=7d

# Session Management (CWE-384, CWE-613)
SESSION_TIMEOUT_MS=900000
# Default: 900000 (15 minutes of inactivity)
MAX_CONCURRENT_SESSIONS=5
# Default: 5 (maximum active sessions per user)

# API Key for Mobile App (CWE-942: CORS Bypass Prevention)
# SECURITY: REQUIRED for production - minimum 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Example: 7a8f3e4c2b1d9f6e5a4c3b2d1f0e9a8b7c6d5e4f3a2b1c0d9e8f7a6b5c4d3e2f
API_KEY=REPLACE_WITH_STRONG_RANDOM_API_KEY_MIN_32_CHARS

# ============================================
# Email Delivery (Equoria-1bvm)
# ============================================
# REQUIRED in NODE_ENV=production (or emailService.mjs throws on send).
# Beta-readiness/beta envs capture emails to disk and do NOT require SMTP.
#
# Use any SMTP-compatible provider (AWS SES, Resend, Postmark, Mailgun, Gmail SMTP).
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_USERNAME
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD
EMAIL_FROM=noreply@equoria.com
EMAIL_FROM_NAME=Equoria
# Public-facing URL bases used inside email bodies (token links):
VERIFICATION_URL_BASE=https://app.equoria.com/verify-email
PASSWORD_RESET_URL_BASE=https://app.equoria.com/reset-password
DASHBOARD_URL=https://app.equoria.com/dashboard
SUPPORT_EMAIL=support@equoria.com

# ============================================
# Feature Flags Configuration
# ============================================
# Naming Convention: FF_<SCOPE>_<FEATURE_NAME>
# Types: Boolean (true/false), Percentage (0-100), String (variant)

# Authentication Flags
FF_AUTH_PASSWORDLESS_LOGIN=false
FF_AUTH_MFA_ENABLED=false
FF_AUTH_SOCIAL_LOGIN=false

# Breeding System Flags
FF_BREEDING_EPIGENETICS=true
FF_BREEDING_NEW_UI=0
FF_BREEDING_RARE_TRAITS=true

# Competition System Flags
FF_COMPETITION_TEAM_EVENTS=false
FF_COMPETITION_LIVE_SCORING=false
FF_COMPETITION_SEASONAL=false

# Training System Flags
FF_TRAINING_NEW_ALGORITHM=0
FF_TRAINING_MINI_GAMES=false

# Groom System Flags
FF_GROOM_SPECIALIZATION=true
FF_GROOM_LEVELING=true

# UI/UX Flags
FF_UI_DARK_MODE=false
FF_UI_ANIMATIONS=true
FF_UI_NEW_DASHBOARD=0

# Marketplace Flags
FF_MARKETPLACE_ENABLED=false
FF_MARKETPLACE_AUCTIONS=false

# Beta/Labs Flags
FF_BETA_FEATURES=
FF_LABS_ENABLED=true

# Performance/Debug Flags
FF_DEBUG_LOGGING=false
FF_PERFORMANCE_TRACING=false

# A/B Test Flags
FF_AB_LANDING_PAGE=control
FF_AB_ONBOARDING_FLOW=control

# ============================================
# AUDIT-LOG RETENTION (OWASP A09 — Equoria-54qq8)
# ============================================
# The audit_logs table persists one row per sensitive mutation. A nightly
# cron (CronJobService job key 'auditLogRetention', 03:30 UTC) purges rows
# older than this window via a scoped DELETE (WHERE createdAt < cutoff).
#
# Default: 90 days (aligned with the 90-day CI audit-report retention).
# Clamped to a 7-day FLOOR — a misconfigured / non-numeric value can never
# effectively disable the trail or wipe near-current forensic history.
# Leave unset to use the 90-day default.
AUDIT_LOG_RETENTION_DAYS=90

# ============================================
# HOOF-CONDITION DECAY (farrier loop — Equoria-gg3v)
# ============================================
# Days per one-rung hoof-condition decay step. A nightly cron
# (CronJobService job key 'hoofConditionDecay', 03:45 UTC) steps a horse's
# Horse.hoofCondition down (excellent→good→fair→poor) one rung per elapsed
# interval since its last farrier visit, prompting re-booking. Decay-only
# (never raises; the farrier improves it) and idempotent (expected level is
# a pure function of elapsed time, not cron-run count). Horses with no
# lastFarrierDate are skipped (no decay anchor).
#
# Default: 30 days. Clamped to a 7-day FLOOR so a misconfigured / non-numeric
# value can never collapse every horse to 'poor' overnight.
# Leave unset to use the 30-day default.
HOOF_CONDITION_DECAY_DAYS=30
