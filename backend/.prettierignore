# WS3 diagnostic artifacts (Equoria-fefh2.15) — gitignored at repo root, but
# prettier runs from backend/ and does not see the root .gitignore entry.
diagnostics/

# Gitignored runtime artifact dirs (Equoria-pfn3p). These are regenerated by
# load/test/coverage runs, are NEVER committed (all gitignored at the repo
# root — load-results/ :116, test-results/ :115, **/coverage/ :108,
# .jest-cache/ :106 of the root .gitignore), and contain machine-emitted
# JSON/HTML that prettier's default formatting does not match (e.g. the load
# driver writes JSON.stringify(summary, null, 2) with no trailing newline).
# `prettier --check .` in the doctrine gate (check-backend-lint-and-format.mjs)
# runs from backend/ and does NOT consult the root .gitignore, so without
# these entries any load/coverage run turns the LOCAL doctrine suite red while
# CI (clean checkout, no artifact files) stays green — a false-positive on
# shipped code. Excluding gitignored, never-shipped artifacts aligns the gate
# with the tree it actually ships (same class as the 21R-CI-1
# --exclude-dir=readiness correction — fixing what the gate scans, NOT
# weakening the gate over shipped source). Source dirs (services/, modules/,
# utils/, etc.) are NOT listed here and remain fully checked.
load-results/
test-results/
coverage/
coverage-partial/
coverage-temp/
coverage-security/
.jest-cache/
