# 🚦 EQUORIA BETA-READINESS ENVIRONMENT CONFIGURATION — EXAMPLE / TEMPLATE
# Copy this to env.beta-readiness (gitignored, never committed) and fill in the
# real local DB password, OR export JWT_SECRET / JWT_REFRESH_SECRET /
# SESSION_SECRET in your shell before running the beta-readiness E2E gates
# under NODE_ENV=beta-readiness.
#
# See docs/testing/BETA_PROFILE.md for full documentation.
#
# IMPORTANT: This file contains ONLY safe placeholders. Never commit real
# credentials. Secrets MUST come from a real secret manager or CI secrets.
#
# Same as env.test but NODE_ENV=beta-readiness so test-only runtime paths
# (e.g., "Server running in test mode" log, rate-limit bypasses keyed to
# JEST_WORKER_ID) are NOT activated. Email capture still works because
# emailService.mjs gates on NODE_ENV !== 'production'.

# ===== DATABASE CONFIGURATION =====
# Reuses the equoria_test DB by default. Override DATABASE_URL in your local
# shell or a gitignored env.beta-readiness file with the real local password.
DATABASE_URL="postgresql://postgres:<your-local-db-password>@localhost:5432/equoria_test"

# ===== SECURITY CONFIGURATION =====
# config.mjs fails hard at startup if JWT_SECRET or JWT_REFRESH_SECRET are
# missing — intentionally. DO NOT add placeholder values for these in any
# committed file: committed defaults make beta-readiness token signing
# predictable and invalidate readiness evidence.
#
# Inject these at runtime via:
#   - CI secrets (GitHub Actions: secrets.JWT_SECRET etc.)
#   - A local gitignored env.beta-readiness file
#   - Shell exports: export JWT_SECRET=<value>
#
# JWT_SECRET=<inject-from-ci-secrets>
# JWT_REFRESH_SECRET=<inject-from-ci-secrets>
# SESSION_SECRET=<inject-from-ci-secrets>
BCRYPT_ROUNDS=10

# ===== RATE LIMITING (Relaxed for readiness gates) =====
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

AUTH_RATE_LIMIT_MAX=50

# ===== SERVER CONFIGURATION =====
NODE_ENV=beta-readiness
PORT=3001
LOG_LEVEL=error

# ===== CORS CONFIGURATION =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===== MONITORING & ALERTS (Disabled for readiness gates) =====
ENABLE_AUDIT_LOGGING=false
ENABLE_SECURITY_ALERTS=false

# ===== GAME CONFIGURATION =====
TRAINING_COOLDOWN_DAYS=0
BREEDING_COOLDOWN_DAYS=0

# ===== JWT CONFIGURATION =====
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=2h

# ===== BETA-READINESS HARNESS SETTINGS =====
# Only the email-capture sink is enabled via EMAIL_CAPTURE_FILE (set by the
# playwright config). No auth, CSRF, ownership, rate-limit, or route bypass is
# enabled in this environment. Production-parity guarantees are required for
# beta-readiness to be valid.
#
# ===== TEST/DEBUG SETTINGS =====
# DO NOT set these in beta-readiness — they defeat the purpose of
# NODE_ENV=beta-readiness by bypassing the very middleware that production-parity
# readiness evidence must exercise.
# SKIP_AUTH_FOR_TESTING=  (intentionally unset — MUST remain unset)
# ENABLE_DEBUG_ROUTES=    (intentionally unset — MUST remain unset)
