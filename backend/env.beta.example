# 🌙 EQUORIA BETA-PROFILE CONFIGURATION — EXAMPLE / TEMPLATE
# Copy this to env.beta.local (never committed) and fill in real secrets,
# OR export JWT_SECRET / JWT_REFRESH_SECRET / SESSION_SECRET in your shell
# before running Playwright under NODE_ENV=beta.
#
# See docs/testing/BETA_PROFILE.md for full documentation.
#
# IMPORTANT: This file contains ONLY safe placeholders. Never commit real
# credentials. Secrets MUST come from a real secret manager or CI secrets.

# ===== DATABASE CONFIGURATION =====
# Reuses the equoria_test DB by default (same DB as env.test), matching the
# "real DB only" project policy. To isolate to a separate equoria_beta DB,
# override DATABASE_URL in your local shell or a .env.beta.local file
# (not committed).
DATABASE_URL="postgresql://postgres:<your-local-db-password>@localhost:5432/equoria_test"

# ===== SECURITY CONFIGURATION =====
# config.mjs fails hard at startup if JWT_SECRET or JWT_REFRESH_SECRET are
# missing — intentionally. DO NOT add placeholder values for these in any
# committed file: committed defaults make beta-runtime token signing
# predictable and defeat the purpose of production-parity testing.
#
# Inject these at runtime via:
#   - CI secrets (GitHub Actions: secrets.JWT_SECRET etc.)
#   - A local .env.beta.local file that is gitignored
#   - Shell exports: export JWT_SECRET=<value>
#
# JWT_SECRET=<inject-from-ci-secrets>
# JWT_REFRESH_SECRET=<inject-from-ci-secrets>
# SESSION_SECRET=<inject-from-ci-secrets>
BCRYPT_ROUNDS=10  # Low cost factor for E2E speed (production uses 10-12)

# ===== RATE LIMITING (Relaxed enough for E2E without bypass headers) =====
# E2E specs must NOT inject x-test-bypass-rate-limit. These caps allow
# beta-critical-path runs to complete without 429s while still enforcing limits.
RATE_LIMIT_WINDOW_MS=60000        # 1 minute
RATE_LIMIT_MAX_REQUESTS=500       # Generous but enforced

AUTH_RATE_LIMIT_MAX=50            # Auth-flow E2E friendly

# ===== SERVER CONFIGURATION =====
NODE_ENV=beta
PORT=3001
LOG_LEVEL=warn  # Less noise than dev, more signal than tests

# ===== CORS CONFIGURATION =====
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===== MONITORING & ALERTS (Production parity) =====
ENABLE_AUDIT_LOGGING=true
ENABLE_SECURITY_ALERTS=true

# ===== GAME CONFIGURATION =====
TRAINING_COOLDOWN_DAYS=0   # E2E friendliness — feature contracts still validated
BREEDING_COOLDOWN_DAYS=0

# ===== JWT CONFIGURATION =====
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=2h

# ===== TEST/DEBUG SETTINGS =====
# DO NOT set these in beta — they defeat the purpose of NODE_ENV=beta by
# bypassing the very middleware that production-parity testing must exercise.
# SKIP_AUTH_FOR_TESTING=  (intentionally unset — MUST remain unset)
# ENABLE_DEBUG_ROUTES=    (intentionally unset — MUST remain unset)
