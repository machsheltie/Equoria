# Equoria-b672b: stray commit-message drafts. Common dev clutter (the
# canonical pattern is to pass commit messages via -m HEREDOC, not a file).
# Adding to gitignore ensures future drafts at repo root aren't tracked
# and don't trip the doctrine bypass-header scans that look for literals
# like x-test-skip-csrf / x-test-bypass-auth.
/commit_message.txt
/commit_message*.txt
/COMMIT_EDITMSG.txt

# Legacy archived node_modules — too-long paths on Windows, not source artifacts
.archive/**/node_modules/

# WS3 full-suite diagnostic artifacts (Equoria-fefh2.15) — never committed
backend/diagnostics/

